# c2o - Claude-to-OpenShift Container
# Based on web-terminal with vllm-sr semantic router and Claude Code

FROM quay.io/eformat/web-terminal:latest

USER 0

# Install additional dependencies
RUN dnf install -y \
    nodejs npm \
    python3 python3-pip python3-pyyaml \
    gettext \
    curl jq nc \
    && dnf clean all

# Install huggingface-cli (required by vllm-sr for model downloads)
RUN pip3 install huggingface_hub[cli]

# Install Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# Create user home structure
RUN mkdir -p /home/user/workspace /home/user/.claude /home/user/.cache/vllm-sr /home/user/.config/gcloud

# Install Grafana OSS
RUN curl -fsSL https://dl.grafana.com/oss/release/grafana-11.6.0.linux-amd64.tar.gz | tar xz -C /opt \
    && ln -s /opt/grafana-v11.6.0 /opt/grafana \
    && ln -s /opt/grafana/bin/grafana-server /usr/local/bin/grafana-server \
    && mkdir -p /etc/grafana/provisioning/datasources /etc/grafana/provisioning/dashboards \
               /var/lib/grafana /var/log/grafana \
    && chown -R 1001:0 /etc/grafana /var/lib/grafana /var/log/grafana /opt/grafana-v11.6.0 \
    && chmod -R g+rwX /etc/grafana /var/lib/grafana /var/log/grafana /opt/grafana-v11.6.0

# Install Prometheus
RUN curl -fsSL https://github.com/prometheus/prometheus/releases/download/v3.4.0/prometheus-3.4.0.linux-amd64.tar.gz | tar xz -C /opt \
    && ln -s /opt/prometheus-3.4.0.linux-amd64 /opt/prometheus \
    && ln -s /opt/prometheus/prometheus /usr/local/bin/prometheus \
    && mkdir -p /var/lib/prometheus \
    && chown -R 1001:0 /var/lib/prometheus /opt/prometheus-3.4.0.linux-amd64 \
    && chmod -R g+rwX /var/lib/prometheus /opt/prometheus-3.4.0.linux-amd64

# Copy envoy binary from the official envoy image
COPY --from=docker.io/envoyproxy/envoy:v1.32-latest /usr/local/bin/envoy /usr/local/bin/envoy

# Copy vllm-sr router binary and libs from the vllm-sr image
COPY --from=quay.io/eformat/vllm-sr:latest /usr/local/bin/router /usr/local/bin/router
COPY --from=quay.io/eformat/vllm-sr:latest /usr/local/lib/libcandle_semantic_router.so /usr/local/lib/
COPY --from=quay.io/eformat/vllm-sr:latest /usr/local/lib/libml_semantic_router.so /usr/local/lib/
COPY --from=quay.io/eformat/vllm-sr:latest /usr/local/lib/libnlp_binding.so /usr/local/lib/

# Copy c2o runtime files
COPY .c2o/entrypoint.sh /usr/local/bin/c2o-entrypoint
RUN chmod +x /usr/local/bin/c2o-entrypoint

# Copy sidecar scripts
COPY .vllm-sr/sidecars/anthropic-proxy/proxy.py /app/sidecars/anthropic-proxy.py
COPY .vllm-sr/sidecars/gcp-token-server/server.py /app/sidecars/gcp-token-server.py

# Copy config templates
COPY vllm-sr-config.yaml /app/config/vllm-sr-config.yaml
COPY config.yaml /app/config/config.yaml
COPY .vllm-sr/envoy/envoy-config.yaml /app/config/envoy-config.yaml
COPY .vllm-sr/grafana/ /app/config/grafana/
COPY .vllm-sr/config/ /app/config/router/

# Set up library path for vllm-sr
ENV LD_LIBRARY_PATH=/usr/local/lib:$LD_LIBRARY_PATH

# Set environment defaults
ENV HOME=/home/user
ENV ANTHROPIC_BASE_URL=http://localhost:8819
ENV ANTHROPIC_API_KEY=sk-ant-api03-proxy-placeholder-AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
ENV UPSTREAM_HOST=localhost
WORKDIR /home/user/workspace

# Expose ports
# 8819 - Anthropic proxy
# 8899 - Envoy/OpenAI API
# 3000 - Grafana
# 9090 - Prometheus
# 9901 - Envoy admin
# 8888 - GCP token server
EXPOSE 8819 8899 3000 9090 9901 8888

USER 1001

ENTRYPOINT ["/usr/local/bin/c2o-entrypoint"]
