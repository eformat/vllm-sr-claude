apiVersion: v1
kind: Secret
metadata:
  name: c2o-env
type: Opaque
stringData:
  # Required: Kimi MaaS API token
  TOKEN: "YOUR_KIMI_TOKEN_HERE"

  # Required: Kimi MaaS hostname (e.g., maas.example.com)
  KIMI_HOST: "YOUR_KIMI_HOST_HERE"

  # Required for Claude models via Vertex AI
  GCP_PROJECT_ID: "YOUR_GCP_PROJECT_ID"

  # Optional: HuggingFace token for faster model downloads
  HF_TOKEN: ""

  # Optional: Grafana admin credentials (defaults to admin/admin)
  GF_SECURITY_ADMIN_USER: "admin"
  GF_SECURITY_ADMIN_PASSWORD: "admin"
